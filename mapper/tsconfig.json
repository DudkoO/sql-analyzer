{
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./",
    "target": "es2021",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "paths": {
      "*": [
        "node_modules/*"
      ],
      "@/*": [
        "./src/*"
      ],
      "@entities/*": [
        "./src/entities/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@enums/*": [
        "./src/enums/*"
      ],
      "@config/*": [
        "./src/config/*"
      ],
      "@interfaces/*": [
        "./src/interfaces/*"
      ],
      "@classes/*": [
        "./src/classes/*"
      ],
      "@constants/*": [
        "./src/constants/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./typings"
    ],
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules"
  ]
}
